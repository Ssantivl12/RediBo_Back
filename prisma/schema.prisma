// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                Int                @id @default(autoincrement())
  nombre            String
  apellido          String
  email             String             @unique
  telefono          String
  direccion         String
  fechaRegistro     DateTime           @default(now())
  contraseña        String
  esAdmin           Boolean            @default(false)
  autos             Auto[]             // Relación con los autos que posee
  comentarios       Comentario[]
}

model Auto {
  id                Int                @id @default(autoincrement())
  marca             String
  modelo            String
  año               Int
  placa             String             @unique
  color             String    
  precioRentaDiario Decimal            @db.Decimal(10, 2)
  montoGarantia     Decimal            @db.Decimal(10, 2)
  estado            EstadoAuto         @default(ACTIVO)  // ACTIVO o INACTIVO (si esta inactivo no sale en el sistema para rentar)
  fechaAdquisicion  DateTime           @default(now())
  kilometraje       Int                @default(0)
  descripcion       String?
  transmision       String
  combustible       String
  capacidad         Int               @db.SmallInt
  capacidadMaletero Int               
  tipoAuto          String
  propietarioId     Int
  propietario       Usuario            @relation(fields: [propietarioId], references: [id])
  historialMantenimiento HistorialMantenimiento[]
  comentarios       Comentario[]
  imagenes          Imagen[]
  disponibilidad    Disponibilidad[]   // Periodos de no disponibilidad (por mantenimiento)
}

model Comentario {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  usuarioId         Int
  usuario           Usuario            @relation(fields: [usuarioId], references: [id])
  contenido         String
  calificacion      Int                @db.SmallInt
  fechaCreacion     DateTime           @default(now())
}

model HistorialMantenimiento {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  fechaInicio       DateTime           @default(now())
  fechaFin          DateTime?
  descripcion       String
  costo             Decimal?           @db.Decimal(10, 2)
  tipoMantenimiento TipoMantenimiento
  kilometraje       Int
}

model Disponibilidad {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  fechaInicio       DateTime
  fechaFin          DateTime
  motivo            MotivoNoDisponibilidad
  descripcion       String?
}

model Imagen {
  id                Int               @id @default(autoincrement())
  autoId            Int
  auto              Auto              @relation(fields: [autoId], references: [id])
  direccionImagen   String            
}

enum MotivoNoDisponibilidad {
  MANTENIMIENTO
  REPARACION
  USO_PERSONAL
  OTRO
}

enum EstadoAuto {
  ACTIVO            // El auto está en la plataforma y puede ser reservado
  INACTIVO          // El auto no está disponible, no puede ser reservado
}

enum TipoMantenimiento {
  PREVENTIVO
  CORRECTIVO
  REVISION
}