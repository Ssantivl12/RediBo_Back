// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo para usuarios
model Usuario {
  id                Int                @id @default(autoincrement())
  nombre            String
  apellido          String
  email             String             @unique
  telefono          String?
  direccion         String?
  fechaRegistro     DateTime           @default(now())
  contraseña        String
  esAdmin           Boolean            @default(false)
  autos             Auto[]             // Relación con los autos que posee
  reservas          Reserva[]          // Relación con sus reservas como cliente
  comentarios       Comentario[]
  
  @@map("usuarios")
}

// Modelo para automóviles
model Auto {
  id                Int                @id @default(autoincrement())
  marca             String
  modelo            String
  año               Int
  placa             String             @unique
  color             String
  precioRentaDiario Decimal            @db.Decimal(10, 2)
  montoGarantia     Decimal            @db.Decimal(10, 2)
  estado            EstadoAuto         @default(ACTIVO)  // ACTIVO o INACTIVO (si esta inactivo no sale en el sistema para rentar)
  fechaAdquisicion  DateTime           @default(now())
  kilometraje       Int                @default(0)
  descripcion       String?
  propietarioId     Int
  propietario       Usuario            @relation(fields: [propietarioId], references: [id])
  reservas          Reserva[]          // Cambiado de rentas a reservas
  historialMantenimiento HistorialMantenimiento[]
  comentarios       Comentario[]
  imagenes          String?
  disponibilidad    Disponibilidad[]   // Periodos de no disponibilidad (por mantenimiento)

  @@map("autos")
}

// Nuevo modelo para gestionar periodos específicos de no disponibilidad (como mantenimiento)
model Disponibilidad {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  fechaInicio       DateTime
  fechaFin          DateTime
  motivo            MotivoNoDisponibilidad
  descripcion       String?
  
  @@map("disponibilidad")
}

// Modelo para reservas de un auto
model Reserva {
  id                Int                @id @default(autoincrement())
  fechaInicio       DateTime
  fechaFin          DateTime
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  clienteId         Int
  cliente           Usuario            @relation(fields: [clienteId], references: [id])
  estado            EstadoReserva      @default(SOLICITADA)
  fechaSolicitud    DateTime           @default(now())
  fechaAprobacion   DateTime?
  fechaLimitePago   DateTime           // Fecha límite para pagar la reserva
  montoTotal        Decimal            @db.Decimal(10, 2) // Monto total de pago
  kilometrajeInicial Int?
  kilometrajeFinal  Int?
  pagos             Pago[]
  garantia          Garantia?
  comentario        Comentario?
  estaPagada        Boolean            @default(false)  // Indica si la reserva está pagada

  @@map("reservas")
}

// Modelo para pagos
model Pago {
  id                Int                @id @default(autoincrement())
  reservaId         Int
  reserva           Reserva            @relation(fields: [reservaId], references: [id])
  monto             Decimal            @db.Decimal(10, 2)
  fechaPago         DateTime           @default(now())
  metodoPago        MetodoPago
  referencia        String?
  comprobante       String?
  tipo              TipoPago           @default(RENTA)  // RENTA O GARANTIA
  
  @@map("pagos")
}

// Modelo para garantías
model Garantia {
  id                Int                @id @default(autoincrement())
  reservaId         Int                @unique
  reserva           Reserva            @relation(fields: [reservaId], references: [id])
  monto             Decimal            @db.Decimal(10, 2)
  fechaDeposito     DateTime           @default(now())
  fechaLiberacion   DateTime?
  estado            EstadoGarantia     @default(DEPOSITADA)
  comprobante       String?
  
  @@map("garantias")
}

// Modelo para historial de mantenimiento
model HistorialMantenimiento {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  fechaInicio       DateTime           @default(now())
  fechaFin          DateTime?
  descripcion       String
  costo             Decimal?           @db.Decimal(10, 2)
  tipoMantenimiento TipoMantenimiento
  kilometraje       Int
  
  @@map("historial_mantenimiento")
}

// Modelo para comentarios
model Comentario {
  id                Int                @id @default(autoincrement())
  autoId            Int
  auto              Auto               @relation(fields: [autoId], references: [id])
  usuarioId         Int
  usuario           Usuario            @relation(fields: [usuarioId], references: [id])
  contenido         String
  calificacion      Int                @db.SmallInt
  fechaCreacion     DateTime           @default(now())
  reservaId         Int?               @unique
  reserva           Reserva?           @relation(fields: [reservaId], references: [id])
  
  @@map("comentarios")
}

// Enumeraciones actualizadas
enum EstadoReserva {
  SOLICITADA        // Rentador pide la reserva
  APROBADA          // Arrendatario aprueba la solicitud, pendiente de pago
  RECHAZADA         // Arrendatario rechaza la solicitud
  CONFIRMADA        // Pagada y lista para ser utilizada
  CANCELADA         // Cancelada por falta de pago o por el arrendatario
  EN_CURSO          // El auto está siendo utilizado actualmente
  FINALIZADA        // Reserva completada
}

enum EstadoGarantia {
  DEPOSITADA
  LIBERADA
  RETENIDA
}

enum MetodoPago {
  QR
  TARJETA_DEBITO
}

enum TipoMantenimiento {
  PREVENTIVO
  CORRECTIVO
  REVISION
}

enum EstadoAuto {
  ACTIVO            // El auto está en la plataforma y puede ser reservado
  INACTIVO          // El auto no está disponible, no puede ser reservado
}

// Motivos por los que un auto no esta disponible por un tiempo en especifico
enum MotivoNoDisponibilidad {
  MANTENIMIENTO
  REPARACION
  USO_PERSONAL
  OTRO
}

enum TipoPago {
  RENTA
  GARANTIA
}