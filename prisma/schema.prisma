// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo para usuarios (arrendatarios y arrendadores)
model Usuario {
  idUsuario         Int                @id @default(autoincrement())
  nombre            String
  apellido          String
  email             String             @unique
  telefono          String?
  direccion         String?
  fechaRegistro     DateTime           @default(now())
  contraseña        String
  esAdmin           Boolean            @default(false)
  rol               RolUsuario       @default(RENTADOR) // Rol del usuario (arrendador, rentador o driver)
  notificaciones    Notificacion[]     // Relación con las notificaciones
  autos             Auto[]             // Relación con los autos que posee
  reservas          Reserva[]          // Relación con sus reservas como cliente
  comentariosEscritos Comentario[]     // Comentarios que este usuario ha escrito sobre autos
  
  @@map("usuarios")
}

// Modelo para notificaciones
model Notificacion {
  idNotificacion            String                @id @default(uuid())
  idUsuario     Int  // ! no me dejo poner el idUsuario como String sin que salga errores, desconozco el motivo
  titulo        String                @db.VarChar(100)
  mensaje       String
  idEntidad     String?
  tipoEntidad   String?               @db.VarChar(50)
  leido         Boolean               @default(false)
  leidoEn       DateTime?
  creadoEn      DateTime              @default(now())
  actualizadoEn DateTime              @updatedAt
  haSidoBorrada Boolean               @default(false)
  tipo          TipoDeNotificacion
  prioridad     PrioridadNotificacion @default(MEDIA)
  usuario       Usuario               @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)

  @@unique([idUsuario, idEntidad, tipo], name: "notificacionUnicaUsuarioEntidad")
  @@index([idUsuario])
  @@index([creadoEn])
  @@index([leido, idUsuario])
  @@index([idUsuario, haSidoBorrada])
}

// Modelo para automóviles 
model Auto {
  idAuto            Int                @id @default(autoincrement())
  idPropietario     Int
  propietario       Usuario            @relation(fields: [idPropietario], references: [idUsuario])
  marca             String
  modelo            String
  descripcion       String?
  precioRentaDiario Decimal            @db.Decimal(10, 2)
  montoGarantia     Decimal            @db.Decimal(10, 2)
  kilometraje       Int                @default(0)
  comentarios       Comentario[]
  calificacionPromedio Float?
  totalComentarios  Int                @default(0)
  reservas          Reserva[]
  disponibilidad    Disponibilidad[]   // Periodos de no disponibilidad (por mantenimiento)
  // ** Detalles adicionales del auto **
  tipo              String             // Tipo de vehículo (Sedán, SUV, Hatchback, etc.)
  año               Int
  placa             String             @unique
  color             String
  estado            EstadoAuto         @default(ACTIVO)  // ACTIVO o INACTIVO (si esta inactivo no sale en el sistema para rentar)
  fechaAdquisicion  DateTime           @default(now())
  historialMantenimiento HistorialMantenimiento[]
  imagenes          Imagen[]           // Relación con las imágenes del auto
  asientos          Int                @default(5) // Cantidad de asientos
  capacidadMaletero Int                // Nueva propiedad: capacidad del maletero
  transmision       Transmision        // Tipo de transmisión (Automático, Manual)
  combustible       Combustible        // Tipo de combustible (Gasolina, Diesel, Eléctrico)
  
  @@map("autos")
}

// Nuevo modelo para imágenes de autos
model Imagen {
  idImagen          Int                @id @default(autoincrement())
  idAuto            Int
  auto              Auto               @relation(fields: [idAuto], references: [idAuto])
  direccionImagen   String             // URL o ruta de la imagen
  
  @@map("imagenes")
}


model Disponibilidad {
  idDisponibilidad  Int                @id @default(autoincrement())
  idAuto            Int
  auto              Auto               @relation(fields: [idAuto], references: [idAuto])
  fechaInicio       DateTime
  fechaFin          DateTime
  motivo            MotivoNoDisponibilidad
  descripcion       String?
  
  @@map("disponibilidad")
}

// Modelo para reservas de un auto
model Reserva {
  idReserva         Int                @id @default(autoincrement())
  fechaInicio       DateTime
  fechaFin          DateTime
  idAuto            Int
  auto              Auto               @relation(fields: [idAuto], references: [idAuto])
  idCliente         Int
  cliente           Usuario            @relation(fields: [idCliente], references: [idUsuario])
  estado            EstadoReserva      @default(SOLICITADA)
  fechaSolicitud    DateTime           @default(now())
  fechaAprobacion   DateTime?
  fechaLimitePago   DateTime           // Fecha límite para pagar la reserva
  montoTotal        Decimal            @db.Decimal(10, 2) // Monto total de pago
  kilometrajeInicial Int?
  kilometrajeFinal  Int?
  pagos             Pago[]
  garantia          Garantia?
  comentario        Comentario?        // Un comentario puede estar asociado a una reserva específica
  estaPagada        Boolean            @default(false)  // Indica si la reserva está pagada

  @@map("reservas")
}

// Modelo para pagos
model Pago {
  idPago            Int                @id @default(autoincrement())
  idReserva         Int
  reserva           Reserva            @relation(fields: [idReserva], references: [idReserva])
  monto             Decimal            @db.Decimal(10, 2)
  fechaPago         DateTime           @default(now())
  metodoPago        MetodoPago
  referencia        String?
  comprobante       String?
  tipo              TipoPago           @default(RENTA)  // RENTA O GARANTIA
  
  @@map("pagos")
}

// Modelo para garantías
model Garantia {
  idGarantia        Int                @id @default(autoincrement())
  idReserva         Int                @unique
  reserva           Reserva            @relation(fields: [idReserva], references: [idReserva])
  monto             Decimal            @db.Decimal(10, 2)
  fechaDeposito     DateTime           @default(now())
  fechaLiberacion   DateTime?
  estado            EstadoGarantia     @default(DEPOSITADA)
  comprobante       String?
  
  @@map("garantias")
}

// Modelo para historial de mantenimiento
model HistorialMantenimiento {
  idHistorial       Int                @id @default(autoincrement())
  idAuto            Int
  auto              Auto               @relation(fields: [idAuto], references: [idAuto])
  fechaInicio       DateTime           @default(now())
  fechaFin          DateTime?
  descripcion       String
  costo             Decimal?           @db.Decimal(10, 2)
  tipoMantenimiento TipoMantenimiento
  kilometraje       Int
  
  @@map("historial_mantenimiento")
}

// Modelo para comentarios
model Comentario {
  idComentario      Int                @id @default(autoincrement())
  idAuto            Int
  auto              Auto               @relation(fields: [idAuto], references: [idAuto])
  idUsuario         Int                // Usuario que escribió el comentario
  usuario           Usuario            @relation(fields: [idUsuario], references: [idUsuario])
  contenido         String
  calificacion      Int                @db.SmallInt
  fechaCreacion     DateTime           @default(now())
  idReserva         Int?               @unique
  reserva           Reserva?           @relation(fields: [idReserva], references: [idReserva])
  
  @@map("comentarios")
}

enum EstadoReserva {
  SOLICITADA        // Rentador pide la reserva
  APROBADA          // Arrendatario aprueba la solicitud, pendiente de pago
  RECHAZADA         // Arrendatario rechaza la solicitud
  CONFIRMADA        // Pagada y lista para ser utilizada
  CANCELADA         // Cancelada por falta de pago o por el arrendatario
  EN_CURSO          // El auto está siendo utilizado actualmente
  FINALIZADA        // Reserva completada
}

enum EstadoGarantia {
  DEPOSITADA
  LIBERADA
  RETENIDA
}

enum MetodoPago {
  QR
  TARJETA_DEBITO
}

enum Transmision {
  AUTOMATICO
  MANUAL
}

enum Combustible {
  GASOLINA
  DIESEL
  ELECTRICO
  HIBRIDO
}

enum TipoMantenimiento {
  PREVENTIVO
  CORRECTIVO
  REVISION
}

enum EstadoAuto {
  ACTIVO            // El auto está en la plataforma y puede ser reservado
  INACTIVO          // El auto no está disponible, no puede ser reservado
}

// Motivos por los que un auto no esta disponible por un tiempo en especifico
enum MotivoNoDisponibilidad {
  MANTENIMIENTO
  REPARACION
  USO_PERSONAL
  OTRO
}

enum TipoPago {
  RENTA
  GARANTIA
}

enum RolUsuario {
  ARRENDADOR
  RENTADOR
  DRIVER
}

enum PrioridadNotificacion {
  BAJA
  MEDIA
  ALTA
}

enum TipoDeNotificacion {
  RESERVA_SOLICITADA // * el rentador solicita una reserva
  RESERVA_APROBADA  // * el arrendador aprueba la reserva
  RESERVA_RECHAZADA // * el arrendador rechaza la reserva
  DEPOSITO_CONFIRMADO // * el rentador confirma la reserva (ya pago)
  DEPOSITO_RECIBIDO
  RESERVA_CANCELADA // * el rentador cancela la reserva o no pago a tiempo
  ALQUILER_FINALIZADO // * culmino la renta del auto
  RESERVA_MODIFICADA
  VEHICULO_CALIFICADO
}